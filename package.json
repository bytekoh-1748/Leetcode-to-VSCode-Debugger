{
  "name": "leetcode-debugger",
  "displayName": "LeetCode Debugger",
  "description": "Debug LeetCode Python solutions in VS Code with same-name case files and helper-type support.",
  "version": "0.1.8",
  "publisher": "YoojinKoh",
  "license": "MIT",
  "pricing": "Free",
  "icon": "media/extension_icon.png",
  "homepage": "https://github.com/bytekoh-1748/Leetcode-to-VSCode-Debugger#readme",
  "bugs": {
    "url": "https://github.com/bytekoh-1748/Leetcode-to-VSCode-Debugger/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bytekoh-1748/Leetcode-to-VSCode-Debugger.git"
  },
  "galleryBanner": {
    "color": "#0b1220"
  },
  "files": [
    "extension.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SUPPORT.md",
    "media/extension_icon.png",
    "python/bootstrap_debug_session.py",
    "python/leetcode_debug_runtime.py"
  ],
  "keywords": [
    "leetcode",
    "python",
    "debugger",
    "competitive-programming",
    "debugpy",
    "interview"
  ],
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Debuggers",
    "Programming Languages"
  ],
  "scripts": {
    "test:runtime": "python3 -m unittest python/test_leetcode_debug_runtime.py",
    "package": "npx @vscode/vsce package",
    "publish:patch": "npx @vscode/vsce publish patch",
    "publish:minor": "npx @vscode/vsce publish minor"
  },
  "activationEvents": [
    "onDebug",
    "onDebugDynamicConfigurations",
    "onCommand:leetcodeDebugger.debugCurrentSolution",
    "onCommand:leetcodeDebugger.openCaseFile"
  ],
  "main": "./extension.js",
  "contributes": {
    "debuggers": [
      {
        "type": "leetcodeDebugger",
        "label": "LeetCode Debugger",
        "configurationAttributes": {
          "launch": {
            "required": [
              "type",
              "request",
              "name"
            ],
            "additionalProperties": true,
            "properties": {
              "type": {
                "enum": [
                  "leetcodeDebugger"
                ],
                "description": "Launch the LeetCode Debugger."
              },
              "request": {
                "enum": [
                  "launch"
                ],
                "description": "Launch the active LeetCode Python solution."
              },
              "name": {
                "type": "string",
                "default": "LeetCode: Debug Current Solution",
                "description": "The name shown in the debug configuration picker."
              },
              "solution": {
                "type": "string",
                "description": "Optional path to the Python solution file. Defaults to the active editor."
              },
              "caseFile": {
                "type": "string",
                "description": "Optional path to the same-name .txt case file. Defaults to the solution's sibling .txt file."
              },
              "cwd": {
                "type": "string",
                "description": "Optional working directory. Defaults to the solution file directory."
              },
              "console": {
                "type": "string",
                "enum": [
                  "integratedTerminal",
                  "internalConsole",
                  "externalTerminal"
                ],
                "default": "integratedTerminal",
                "description": "Where to launch the debug session."
              },
              "justMyCode": {
                "type": "boolean",
                "default": true
              },
              "stopOnEntry": {
                "type": "boolean",
                "default": false
              },
              "subProcess": {
                "type": "boolean",
                "default": false
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "name": "LeetCode: Debug Current Solution",
            "type": "leetcodeDebugger",
            "request": "launch"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "leetcodeDebugger.debugCurrentSolution",
        "title": "LeetCode: Debug Current Solution"
      },
      {
        "command": "leetcodeDebugger.openCaseFile",
        "title": "LeetCode: Open Case File"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "leetcodeDebugger.debugCurrentSolution",
          "group": "navigation@100",
          "when": "resourceExtname == .py"
        },
        {
          "command": "leetcodeDebugger.openCaseFile",
          "group": "navigation@101",
          "when": "resourceExtname == .py"
        }
      ],
      "commandPalette": [
        {
          "command": "leetcodeDebugger.debugCurrentSolution",
          "when": "editorTextFocus"
        },
        {
          "command": "leetcodeDebugger.openCaseFile",
          "when": "editorTextFocus"
        }
      ]
    }
  },
  "extensionDependencies": [
    "ms-python.python",
    "ms-python.debugpy"
  ]
}
